@model HRM.Web.Models.ViewModels.Departments.DepartmentMembersViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Quan ly nhan vien phong ban";
    var transferDepartments = ViewBag.TransferDepartments as List<SelectListItem> ?? new List<SelectListItem>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Nhan vien - @Model.DeptName</h2>
    <a class="btn btn-secondary" asp-action="Index">Quay lai</a>
</div>

@if (!string.IsNullOrWhiteSpace(TempData["Success"] as string))
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (!string.IsNullOrWhiteSpace(TempData["Error"] as string))
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row g-4">
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-body">
                <h5>Them nhan vien vao phong ban</h5>
                <form asp-action="AssignEmployees" asp-route-id="@Model.DeptId" method="post">
                    @Html.AntiForgeryToken()
                    <select class="form-select mb-3" name="employeeIds" size="12" multiple>
                        @foreach (var employee in Model.AvailableEmployees)
                        {
                            <option value="@employee.EmpId">@employee.Name (#@employee.EmpId) - @employee.Email</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-primary">Them vao phong ban</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-body">
                <h5>Danh sach hien tai (@Model.CurrentEmployees.Count)</h5>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nhan vien</th>
                                <th>Email</th>
                                <th>Dieu chuyen</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model.CurrentEmployees.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">Chua co nhan vien.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var employee in Model.CurrentEmployees)
                            {
                                <tr>
                                    <td>@employee.EmpId</td>
                                    <td>@employee.Name</td>
                                    <td>@employee.Email</td>
                                    <td>
                                        <form asp-action="TransferEmployee" asp-route-id="@Model.DeptId" method="post" class="d-flex gap-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="employeeId" value="@employee.EmpId" />
                                            <select name="targetDeptId" class="form-select form-select-sm" required>
                                                <option value="">-- Sang phong ban --</option>
                                                @foreach (var dept in transferDepartments)
                                                {
                                                    <option value="@dept.Value">@dept.Text</option>
                                                }
                                            </select>
                                            <button class="btn btn-sm btn-outline-dark" type="submit">Chuyen</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
