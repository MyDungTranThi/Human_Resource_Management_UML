@model HRM.Web.Models.ViewModels.Departments.DepartmentIndexViewModel
@{
    ViewData["Title"] = "Quản lý phòng ban";
}

<div class="page-head page-head-actions">
    <div>
        <h1>Quản lý phòng ban</h1>
        <p>Quản lý trưởng phòng, thành viên và cấu trúc bộ phận.</p>
    </div>
    <div class="head-actions">
        <a class="secondary-btn" asp-action="ExportPdf"><i class="bi bi-filetype-pdf"></i> Xuất PDF</a>
        <a class="secondary-btn" asp-action="ExportExcel"><i class="bi bi-file-earmark-excel"></i> Xuất Excel</a>
        <a class="primary-btn" asp-action="Create"><i class="bi bi-plus-square-fill"></i> Thêm phòng ban</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(TempData["Success"] as string))
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (!string.IsNullOrWhiteSpace(TempData["Error"] as string))
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<section class="panel mb-4">
    <form method="get" class="filter-grid">
        <div>
            <label class="form-label">Tìm kiếm</label>
            <input class="form-control" name="search" value="@Model.Search" placeholder="Tìm kiếm phòng ban hoặc quản lý..." />
        </div>
        <div>
            <label class="form-label">Số dòng</label>
            <select class="form-select" name="pageSize">
                @foreach (var size in new[] { 10, 20, 50 })
                {
                    <option value="@size" selected="@(Model.PageSize == size)">@size</option>
                }
            </select>
        </div>
        <div class="filter-actions">
            <button class="primary-btn" type="submit"><i class="bi bi-funnel-fill"></i> Áp dụng bộ lọc</button>
            <a class="secondary-btn" asp-action="Index">Xóa</a>
        </div>
    </form>
</section>

<section class="panel">
    <div class="table-responsive">
        <table class="table table-modern align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Phòng ban</th>
                    <th>Quản lý</th>
                    <th>Thành viên</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.PagedDepartments.Items.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted">Không tìm thấy phòng ban nào.</td></tr>
                }
                else
                {
                    foreach (var dept in Model.PagedDepartments.Items)
                    {
                        <tr>
                            <td>#@dept.DeptId</td>
                            <td><strong>@dept.DeptName</strong></td>
                            <td>@dept.DeptManager.Name</td>
                            <td><span class="status-tag processed">@dept.Employees.Count thành viên</span></td>
                            <td>
                                <div class="action-inline">
                                    <a class="icon-link" asp-action="Members" asp-route-id="@dept.DeptId" title="Thành viên"><i class="bi bi-people"></i></a>
                                    <a class="icon-link" asp-action="Edit" asp-route-id="@dept.DeptId" title="Chỉnh sửa"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" asp-route-id="@dept.DeptId" method="post" onsubmit="return confirm('Xóa phòng ban này?');">
                                        @Html.AntiForgeryToken()
                                        <button class="icon-link danger" type="submit" title="Xóa"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model.PagedDepartments.TotalPages > 1)
    {
        <nav class="pager-wrap">
            <span>Trang @Model.PagedDepartments.Page trên @Model.PagedDepartments.TotalPages</span>
            <ul class="pagination mb-0">
                @for (var i = 1; i <= Model.PagedDepartments.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PagedDepartments.Page ? "active" : string.Empty)">
                        <a class="page-link" asp-action="Index" asp-route-search="@Model.Search" asp-route-page="@i" asp-route-pageSize="@Model.PageSize">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</section>
