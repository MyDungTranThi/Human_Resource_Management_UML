@model HRM.Web.Models.ViewModels.Departments.DepartmentFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<div class="mb-3">
    <label asp-for="DeptName" class="form-label"></label>
    <input asp-for="DeptName" class="form-control" />
    <span asp-validation-for="DeptName" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="DeptManagerId" class="form-label">Department Head</label>
    <select asp-for="DeptManagerId" asp-items="Model.Managers" class="form-select">
        <option value="">-- Chon truong phong --</option>
    </select>
    <span asp-validation-for="DeptManagerId" class="text-danger"></span>
</div>
