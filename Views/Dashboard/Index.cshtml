@model HRM.Web.Models.ViewModels.Dashboard.DashboardViewModel
@using HRM.Web.Models.Constants
@{
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="page-head">
    <div>
        <h1>Bảng điều khiển</h1>
        <p>Chào mừng, @User.Identity?.Name. Đây là tổng quan hoạt động nhân sự hôm nay.</p>
    </div>
</div>

<section class="metric-grid">
    <article class="metric-card">
        <div class="metric-icon icon-blue"><i class="bi bi-people-fill"></i></div>
        <div class="metric-label">Tổng số nhân sự</div>
        <div class="metric-value">@Model.EmployeeCount.ToString("N0")</div>
        <div class="metric-note">+4% so với tháng trước</div>
    </article>

    <article class="metric-card">
        <div class="metric-icon icon-mint"><i class="bi bi-diagram-3-fill"></i></div>
        <div class="metric-label">Dự án đang hoạt động</div>
        <div class="metric-value">@Model.ActiveProjectCount.ToString("N0")</div>
        <div class="metric-note">Tổng @Model.ProjectCount dự án</div>
    </article>

    <article class="metric-card">
        <div class="metric-icon icon-peach"><i class="bi bi-cash-stack"></i></div>
        <div class="metric-label">Tổng lương tháng</div>
        <div class="metric-value">@Model.ThisMonthPayrollTotal.ToString("N0")</div>
        <div class="metric-note">Đã xử lý</div>
    </article>

    <article class="metric-card">
        <div class="metric-icon icon-violet"><i class="bi bi-person-plus-fill"></i></div>
        <div class="metric-label">Số phòng ban</div>
        <div class="metric-value">@Model.DepartmentCount</div>
        <div class="metric-note">Đơn vị chức năng</div>
    </article>
</section>

<section class="content-grid two-columns mt-4">
    <article class="panel">
        <div class="panel-head">
            <h4>Xu hướng lương</h4>
            <span class="chip">Năm @DateTime.Today.Year</span>
        </div>
        <div class="bar-chart">
            @{
                var maxSalaryTrend = Model.SalaryTrend.Any() ? Model.SalaryTrend.Max(x => x.Total) : 0;
            }
            @foreach (var stat in Model.SalaryTrend)
            {
                var height = maxSalaryTrend > 0 ? (int)(stat.Total / maxSalaryTrend * 100) : 0;
                <div style="height:@(height)%" title="@stat.MonthLabel: @stat.Total.ToString("N0")"></div>
            }
        </div>
        <div class="bar-labels">
            @foreach (var stat in Model.SalaryTrend)
            {
                <span>@stat.MonthLabel</span>
            }
        </div>
    </article>

    <article class="panel">
        <h4>Phân bổ nhân sự</h4>
        <div class="distribution-wrap">
            <div class="donut"></div>
            <ul>
                @{
                    var colors = new[] { "blue", "mint", "violet", "peach" };
                    int colorIdx = 0;
                }
                @foreach (var dept in Model.DeptDistribution.Take(4))
                {
                    <li><span class="dot @colors[colorIdx % 4]"></span>@dept.DeptName (@dept.Percentage%)</li>
                    colorIdx++;
                }
            </ul>
        </div>
    </article>
</section>

<section class="content-grid two-columns mt-4">
    <article class="panel">
        <div class="panel-head">
            <h4>Hoạt động gần đây</h4>
            <a class="link-help" asp-controller="Absences" asp-action="Index">Xem tất cả</a>
        </div>

        <div class="table-responsive">
            <table class="table table-modern">
                <thead>
                    <tr>
                        <th>Nhân viên</th>
                        <th>Hoạt động</th>
                        <th>Ngày</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Activities.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">Không có hoạt động gần đây.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var act in Model.Activities)
                        {
                            <tr>
                                <td>@act.EmployeeName<br /><small>@act.DeptName</small></td>
                                <td>@act.Action</td>
                                <td>@act.DateLabel</td>
                                <td><span class="status-tag @act.StatusClass">@act.Status</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </article>

    <article class="panel panel-highlight">
        <h4>Lối tắt theo vai trò</h4>
        <p>Vai trò hiện tại: <strong>@Model.CurrentRole</strong></p>

        <div class="shortcut-grid">
            @if (User.HasAnyRole(AppRoles.Admin, AppRoles.HR))
            {
                <a asp-controller="Employees" asp-action="Index" class="shortcut-btn"><i class="bi bi-people"></i> Danh sách nhân sự</a>
            }
            @if (User.HasAnyRole(AppRoles.Admin, AppRoles.Accountant))
            {
                <a asp-controller="Payroll" asp-action="Index" class="shortcut-btn"><i class="bi bi-calculator"></i> Trung tâm lương</a>
            }
            @if (User.HasAnyRole(AppRoles.Admin, AppRoles.Manager))
            {
                <a asp-controller="Projects" asp-action="Index" class="shortcut-btn"><i class="bi bi-kanban"></i> Quản lý dự án</a>
                <a asp-controller="Departments" asp-action="Index" class="shortcut-btn"><i class="bi bi-diagram-3"></i> Quản lý phòng ban</a>
            }
            <a asp-controller="Reports" asp-action="Index" class="shortcut-btn"><i class="bi bi-bar-chart"></i> Báo cáo thống kê</a>
        </div>
    </article>
</section>
