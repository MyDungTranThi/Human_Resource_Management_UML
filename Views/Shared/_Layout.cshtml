@using HRM.Web.Helpers
@using HRM.Web.Models.Constants
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var isAuthPage = string.Equals(currentController, "Auth", StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, "Login", StringComparison.OrdinalIgnoreCase);

    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var canUseHr = User.HasAnyRole(AppRoles.Admin, AppRoles.HR);
    var canUsePayroll = User.HasAnyRole(AppRoles.Admin, AppRoles.Accountant);
    var canUseManagement = User.HasAnyRole(AppRoles.Admin, AppRoles.Manager);
    var canUseReports = User.HasAnyRole(AppRoles.Admin, AppRoles.HR, AppRoles.Manager, AppRoles.Accountant);
    var canManageAccounts = User.HasAnyRole(AppRoles.Admin);

    string NavClass(bool active) => active ? "app-nav-link active" : "app-nav-link";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HRM Quản lý nhân sự</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HRM.Web.styles.css" asp-append-version="true" />
</head>
<body class="@(isAuthenticated ? "app-authenticated" : "app-guest")">
    @if (isAuthenticated && !isAuthPage)
    {
        <div class="app-shell">
            <aside class="app-sidebar">
                <div class="app-brand">
                    <div class="app-brand-icon"><i class="bi bi-buildings-fill"></i></div>
                    <div>
                        <div class="app-brand-title">HRM Doanh nghiệp</div>
                        <div class="app-brand-subtitle">Quản lý nhân sự</div>
                    </div>
                </div>

                <nav class="app-nav">
                    <a class="@NavClass(currentController == "Dashboard")" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span>Bảng điều khiển</span>
                    </a>

                    @if (canUseHr)
                    {
                        <a class="@NavClass(currentController == "Employees")" asp-controller="Employees" asp-action="Index">
                            <i class="bi bi-people-fill"></i>
                            <span>Nhân sự</span>
                        </a>
                        <a class="@NavClass(currentController == "Absences")" asp-controller="Absences" asp-action="Index">
                            <i class="bi bi-calendar-x-fill"></i>
                            <span>Quản lý ngày nghỉ</span>
                        </a>
                    }

                    @if (canUsePayroll)
                    {
                        <a class="@NavClass(currentController == "Payroll")" asp-controller="Payroll" asp-action="Index">
                            <i class="bi bi-cash-stack"></i>
                            <span>Tiền lương</span>
                        </a>
                    }

                    @if (canUseManagement)
                    {
                        <a class="@NavClass(currentController == "Projects")" asp-controller="Projects" asp-action="Index">
                            <i class="bi bi-kanban-fill"></i>
                            <span>Dự án</span>
                        </a>
                        <a class="@NavClass(currentController == "Departments")" asp-controller="Departments" asp-action="Index">
                            <i class="bi bi-diagram-3-fill"></i>
                            <span>Phòng ban</span>
                        </a>
                    }

                    @if (canUseReports)
                    {
                        <a class="@NavClass(currentController == "Reports")" asp-controller="Reports" asp-action="Index">
                            <i class="bi bi-bar-chart-fill"></i>
                            <span>Báo cáo</span>
                        </a>
                    }

                    @if (canManageAccounts)
                    {
                        <a class="@NavClass(currentController == "Accounts")" asp-controller="Accounts" asp-action="Index">
                            <i class="bi bi-person-badge-fill"></i>
                            <span>Tài khoản</span>
                        </a>
                    }

                    <a class="@NavClass(currentController == "Home" && currentAction == "Privacy")" asp-controller="Home" asp-action="Privacy">
                        <i class="bi bi-gear-fill"></i>
                        <span>Cài đặt</span>
                    </a>
                </nav>

                <div class="sidebar-user">
                    <div class="avatar-circle">@((User.Identity?.Name ?? "U").Substring(0, 1).ToUpperInvariant())</div>
                    <div>
                        <div class="user-name">@User.Identity?.Name</div>
                        <div class="user-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                    </div>
                </div>
            </aside>

            <div class="app-main">
                <header class="app-topbar">
                    <label class="app-search">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Tìm nhân sự, lương, dự án..." />
                    </label>

                    <div class="topbar-actions">
                        <button type="button" class="icon-btn"><i class="bi bi-bell"></i></button>
                        <button type="button" class="icon-btn"><i class="bi bi-question-circle"></i></button>
                        <button type="button" class="icon-btn"><i class="bi bi-gear"></i></button>

                        @if (canUseHr)
                        {
                            <a class="primary-btn" asp-controller="Employees" asp-action="Create"><i class="bi bi-person-plus-fill"></i> Thêm nhân sự</a>
                        }
                        else if (canUsePayroll)
                        {
                            <a class="primary-btn" asp-controller="Payroll" asp-action="Index"><i class="bi bi-calculator-fill"></i> Tính lương</a>
                        }
                        else if (canUseManagement)
                        {
                            <a class="primary-btn" asp-controller="Projects" asp-action="Create"><i class="bi bi-plus-square-fill"></i> Tạo dự án</a>
                        }

                        <form asp-controller="Auth" asp-action="Logout" method="post" class="logout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="secondary-btn">Đăng xuất</button>
                        </form>
                    </div>
                </header>

                <main class="app-content">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <div class="guest-wrapper">
            @RenderBody()
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
