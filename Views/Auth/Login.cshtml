@model HRM.Web.Models.ViewModels.Auth.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập hệ thống";
}

<div class="login-shell">
    <section class="login-visual">
        <div class="visual-hero">
            <div class="visual-light"></div>
        </div>

        <h2>MDXD COMPANY</h2>
        <p>
            Nâng cao hiệu quả quản lý nhân sự với hệ thống tập trung lương, dự án và nhân sự.
        </p>

        <div class="visual-features">
            <article>
                <i class="bi bi-diagram-3-fill"></i>
                <h6>Quản lý dự án</h6>
                <span>Giám sát tiến độ và nguồn lực theo thời gian thực.</span>
            </article>
            <article>
                <i class="bi bi-credit-card-2-front-fill"></i>
                <h6>Quản lý lương</h6>
                <span>Tự động tính lương chính xác, tuân thủ đầy đủ.</span>
            </article>
        </div>
    </section>

    <section class="login-form-wrap">
        <div class="login-form-card">
            <h3>Chào mừng trở lại</h3>
            <p>Đăng nhập để vào hệ thống quản lý nhân sự</p>

            <form asp-action="Login" method="post" class="login-form">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <label>Tên đăng nhập</label>
                <div class="input-icon">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="Username" class="form-control" placeholder="Tên đăng nhập" />
                </div>
                <span asp-validation-for="Username" class="text-danger"></span>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <label class="mb-0">Mật khẩu</label>
                    <a href="#" class="link-help">Quên mật khẩu?</a>
                </div>
                <div class="input-icon">
                    <i class="bi bi-lock"></i>
                    <input asp-for="Password" class="form-control" placeholder="Mật khẩu" />
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>

                @if (!string.IsNullOrWhiteSpace(ViewBag.Error as string))
                {
                    <div class="alert alert-danger mt-3">@ViewBag.Error</div>
                }

                <div class="form-check mt-3">
                    <input class="form-check-input" type="checkbox" id="rememberDevice" />
                    <label class="form-check-label" for="rememberDevice">Ghi nhớ đăng nhập trong 30 ngày</label>
                </div>

                <button type="submit" class="primary-btn w-100 mt-3">Đăng nhập</button>
            </form>

            <div class="login-separator">HOẶC ĐĂNG NHẬP BẰNG SSO</div>
            <div class="sso-grid">
                <button type="button"><i class="bi bi-google"></i> Google</button>
                <button type="button"><i class="bi bi-microsoft"></i> Microsoft</button>
            </div>

            <p class="text-center mt-4 text-muted small mb-0">
                Cần quyền truy cập? <strong>Liên hệ Quản trị hệ thống</strong>
            </p>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
