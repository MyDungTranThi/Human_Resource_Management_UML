@model HRM.Web.Models.ViewModels.Auth.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập hệ thống";
    Layout = null; // Do not use _Layout to avoid CSS conflicts
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        
        * { box-sizing: border-box; font-family: 'Inter', sans-serif; }
        body { margin: 0; padding: 0; background: #fff; height: 100vh; display: flex; }
        
        .login-split {
            display: flex;
            width: 100%;
            height: 100vh;
        }

        /* LEFT SIDE */
        .login-left {
            flex: 1;
            /* Thay thế màu đơn sắc thành hình ảnh công ty/văn phòng */
            background: linear-gradient(rgba(39, 90, 235, 0.75), rgba(15, 47, 127, 0.9)), 
                        url('https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=1200') no-repeat center center;
            background-size: cover;
            color: #fff;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 60px;
        }

        .left-text {
            position: relative;
            z-index: 10;
            text-align: center;
        }
        .left-text h2 {
            font-size: 38px;
            font-weight: 700;
            margin-bottom: 20px;
            line-height: 1.3;
        }
        .left-text p {
            font-size: 16px;
            color: rgba(255,255,255,0.9);
            line-height: 1.6;
            max-width: 400px;
            margin: 0 auto 40px auto;
        }

        /* RIGHT SIDE */
        .login-right {
            flex: 1.1;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .form-wrapper {
            width: 100%;
            max-width: 420px;
            padding: 40px;
        }
        
        .logo-wrap {
            text-align: center;
            margin-bottom: 30px;
        }
        .logo-wrap .icon-circle {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            border: 1px solid #f0f0f0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: #275aeb;
            box-shadow: 0 4px 10px rgba(0,0,0,0.03);
        }

        .form-header {
            text-align: center;
            margin-bottom: 35px;
        }
        .form-header h3 {
            font-size: 28px;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 12px;
        }
        .form-header p {
            font-size: 14px;
            color: #9ca3af;
            line-height: 1.5;
            margin: 0;
            padding: 0 20px;
        }

        .input-group {
            position: relative;
            margin-bottom: 24px;
        }
        
        .floating-label {
            position: absolute;
            top: -8px;
            left: 15px;
            background: #fff;
            padding: 0 5px;
            font-size: 12px;
            color: #275aeb;
            font-weight: 500;
        }

        .input-control {
            width: 100%;
            height: 52px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 0 40px 0 16px;
            font-size: 15px;
            color: #1f2937;
            outline: none;
            transition: all 0.2s;
        }
        .input-control:focus {
            border-color: #275aeb;
            box-shadow: 0 0 0 3px rgba(39, 90, 235, 0.1);
        }
        
        .input-group.has-value .input-control {
            border-color: #275aeb;
        }

        .input-icon {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 18px;
        }

        .form-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
            margin-bottom: 30px;
        }
        .checkbox-wrap {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #6b7280;
            cursor: pointer;
        }
        .checkbox-wrap input {
            accent-color: #275aeb;
            width: 16px;
            height: 16px;
            cursor: pointer;
            border-radius: 4px;
            border: 1px solid #d1d5db;
        }
        .forgot-link {
            color: #275aeb;
            text-decoration: none;
            font-weight: 600;
        }

        .btn-primary {
            width: 100%;
            height: 52px;
            background: #275aeb;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
            margin-bottom: 16px;
        }
        .btn-primary:hover {
            background: #1e45b8;
        }

        .btn-google {
            width: 100%;
            height: 52px;
            background: #fff;
            color: #4b5563;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            transition: background 0.2s;
        }
        .btn-google:hover {
            background: #f9fafb;
        }

        .text-danger { color: #dc2626; font-size: 13px; margin-top: 5px; display: block; }
        .alert-danger { background: #fee2e2; color: #991b1b; padding: 12px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; text-align: center; }

        @@media (max-width: 992px) {
            .login-split { flex-direction: column; }
            .login-left { display: none; }
        }
    </style>
</head>
<body>
    <div class="login-split">
        <div class="login-left">
            <div class="left-text">
                <h2>HRM Doanh Nghiệp</h2>
                <p>Nền tảng quản lý nhân sự chuyên nghiệp, giúp tối ưu hoá vận hành và mang lại môi trường làm việc hiệu quả cho công ty.</p>
                <div style="display:flex; justify-content:center; gap:6px;">
                    <div style="width:18px; height:5px; background:#fff; border-radius:3px;"></div>
                    <div style="width:5px; height:5px; background:rgba(255,255,255,0.4); border-radius:3px;"></div>
                    <div style="width:5px; height:5px; background:rgba(255,255,255,0.4); border-radius:3px;"></div>
                </div>
            </div>
        </div>
        
        <div class="login-right">
            <div class="form-wrapper">
                <div class="logo-wrap">
                    <div class="icon-circle">
                        <i class="bi bi-buildings"></i>
                    </div>
                </div>

                <div class="form-header">
                    <h3>Hello Again!</h3>
                    <p>Chào mừng bạn quay lại hệ thống quản lý. Vui lòng đăng nhập để tiếp tục.</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(ViewBag.Error as string))
                {
                    <div class="alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="input-group has-value">
                        <span class="floating-label">Email / Tên đăng nhập</span>
                        <!-- Dùng Username thay cho Email vì logic backend nhận Username -->
                        <input asp-for="Username" class="input-control" placeholder="Nhập tài khoản" autofocus />
                        <i class="bi bi-person input-icon" style="color: #275aeb;"></i>
                    </div>
                    <span asp-validation-for="Username" class="text-danger" style="margin-top:-15px; margin-bottom:15px;"></span>

                    <div class="input-group">
                        <input asp-for="Password" type="password" class="input-control" placeholder="Mật khẩu" />
                        <i class="bi bi-lock input-icon"></i>
                    </div>
                    <span asp-validation-for="Password" class="text-danger" style="margin-top:-15px; margin-bottom:15px;"></span>

                    <div class="form-options">
                        <label class="checkbox-wrap">
                            <input type="checkbox" name="rememberMe" id="rememberMe" />
                            <span>Ghi nhớ đăng nhập</span>
                        </label>
                        <a href="#" class="forgot-link">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="btn-primary">Đăng nhập</button>
                    
                    <button type="button" class="btn-google">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                        </svg>
                        Đăng nhập bằng Google
                    </button>
                </form>
            </div>
        </div>
    </div>
    
    <script>
        // JS để xử lý hiệu ứng floating label khi ô có dữ liệu
        const inputs = document.querySelectorAll('.input-control');
        inputs.forEach(input => {
            input.addEventListener('focus', () => {
                input.parentElement.classList.add('has-value');
            });
            input.addEventListener('blur', () => {
                if(!input.value) {
                    input.parentElement.classList.remove('has-value');
                }
            });
        });
    </script>
</body>
</html>
