@model HRM.Web.Models.ViewModels.Employees.EmployeeFormViewModel
@{
    ViewData["Title"] = "Them nhan vien";
}

<h2 class="mb-3">Them nhan vien</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <partial name="_EmployeeForm" model="Model" />

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Luu</button>
        <a class="btn btn-secondary" asp-action="Index">Quay lai</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
