@model HRM.Web.Models.ViewModels.Employees.EmployeeFormViewModel
@{
    ViewData["Title"] = "Cap nhat nhan vien";
}

<h2 class="mb-3">Cap nhat nhan vien #@Model.EmpId</h2>

<form asp-action="Edit" asp-route-id="@Model.EmpId" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="EmpId" type="hidden" />

    <partial name="_EmployeeForm" model="Model" />

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Cap nhat</button>
        <a class="btn btn-secondary" asp-action="Index">Quay lai</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
