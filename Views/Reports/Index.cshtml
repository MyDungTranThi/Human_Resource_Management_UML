@model HRM.Web.Models.ViewModels.Reports.ReportsDashboardViewModel
@using HRM.Web.Models.Constants
@{
    ViewData["Title"] = "Báo cáo thống kê";
}

<div class="page-head page-head-actions">
    <div>
        <h1>Báo cáo thống kê</h1>
        <p>Xem tổng quan hiệu suất tổ chức và danh sách chi tiết theo phân quyền của bạn.</p>
    </div>
    <div class="head-actions">
        <a class="secondary-btn" asp-controller="Payroll" asp-action="ExportPdf" asp-route-month="@DateTime.Today.Month" asp-route-year="@DateTime.Today.Year"><i class="bi bi-filetype-pdf"></i> Xuất PDF</a>
        <a class="primary-btn" asp-controller="Payroll" asp-action="ExportExcel" asp-route-month="@DateTime.Today.Month" asp-route-year="@DateTime.Today.Year"><i class="bi bi-file-earmark-excel"></i> Xuất Excel</a>
    </div>
</div>

<section class="metric-grid mb-4">
    @if (Model.ShowHrMetrics)
    {
        <article class="metric-card">
            <div class="metric-icon icon-blue"><i class="bi bi-people-fill"></i></div>
            <div class="metric-label">Tổng số nhân sự</div>
            <div class="metric-value">@Model.TotalHeadcount.ToString("N0")</div>
        </article>

        <article class="metric-card">
            <div class="metric-icon" style="background:#ffe0e0; color:#c53a3a;"><i class="bi bi-person-dash-fill"></i></div>
            <div class="metric-label">Nghỉ nhiều nhất</div>
            @if (!string.IsNullOrEmpty(Model.MostAbsentEmployeeName))
            {
                <div class="metric-value" style="font-size: 20px;">@Model.MostAbsentEmployeeName</div>
                <div class="metric-note">@Model.MostAbsentCount ngày vắng mặt</div>
            }
            else
            {
                <div class="metric-value" style="font-size: 20px;">Không có</div>
            }
        </article>
    }

    @if (Model.ShowAccountantMetrics)
    {
        <article class="metric-card">
            <div class="metric-icon icon-mint"><i class="bi bi-cash-stack"></i></div>
            <div class="metric-label">Chi phí lương (Tháng @DateTime.Today.Month)</div>
            <div class="metric-value">@Model.PayrollCost.ToString("N0")</div>
        </article>
    }

    @if (Model.ShowManagerMetrics)
    {
        <article class="metric-card">
            <div class="metric-icon icon-peach"><i class="bi bi-diagram-3-fill"></i></div>
            <div class="metric-label">Tổng phòng ban</div>
            <div class="metric-value">@Model.TotalDepartments.ToString("N0")</div>
        </article>
        
        <article class="metric-card">
            <div class="metric-icon icon-violet"><i class="bi bi-kanban-fill"></i></div>
            <div class="metric-label">Tổng dự án</div>
            <div class="metric-value">@Model.TotalProjects.ToString("N0")</div>
        </article>
    }
</section>

<!-- HR Lists -->
@if (Model.ShowHrMetrics)
{
    <div class="row">
        <div class="col-md-7">
            <section class="panel mb-4">
                <h4>Danh sách nhân sự</h4>
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-modern align-middle">
                        <thead style="position: sticky; top: 0; background: #fff; z-index: 1;">
                            <tr>
                                <th>Mã NV</th>
                                <th>Tên nhân viên</th>
                                <th>Phòng ban</th>
                                <th>Chức vụ</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.HrEmployeeList)
                            {
                                <tr>
                                    <td><strong>#@item.EmpId</strong></td>
                                    <td>@item.Name</td>
                                    <td>@item.Department</td>
                                    <td><span class="status-tag processed">@item.Position</span></td>
                                    <td>
                                        @if(item.Status == "Active")
                                        {
                                            <span class="status-tag active">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="status-tag pending">Nghỉ việc</span>
                                        }
                                    </td>
                                </tr>
                            }
                            @if (!Model.HrEmployeeList.Any())
                            {
                                <tr><td colspan="5" class="text-center text-muted">Không có dữ liệu</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
        <div class="col-md-5">
            <section class="panel mb-4">
                <h4>Danh sách vắng mặt gần đây</h4>
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-modern align-middle">
                        <thead style="position: sticky; top: 0; background: #fff; z-index: 1;">
                            <tr>
                                <th>Nhân viên</th>
                                <th>Ngày vắng</th>
                                <th>Lý do</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.HrAbsenceList)
                            {
                                <tr>
                                    <td><strong>@item.EmployeeName</strong></td>
                                    <td>@item.Date</td>
                                    <td><small>@item.Reason</small></td>
                                </tr>
                            }
                            @if (!Model.HrAbsenceList.Any())
                            {
                                <tr><td colspan="3" class="text-center text-muted">Không có dữ liệu</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>
}

<!-- Accountant Lists -->
@if (Model.ShowAccountantMetrics)
{
    <section class="panel mb-4">
        <h4>Danh sách bảng lương (Tháng @DateTime.Today.Month)</h4>
        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
            <table class="table table-modern align-middle">
                <thead style="position: sticky; top: 0; background: #fff; z-index: 1;">
                    <tr>
                        <th>Xếp hạng</th>
                        <th>Tên nhân viên</th>
                        <th>Phòng ban</th>
                        <th>Lương thực nhận</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int rank = 1; }
                    @foreach (var item in Model.SalaryRanking)
                    {
                        <tr>
                            <td style="width:100px;">
                                @if (rank == 1) { <span class="status-tag" style="background:#ffd700; color:#856404;">#1 Top Earner</span> }
                                else if (rank == 2) { <span class="status-tag" style="background:#e0e0e0; color:#424242;">#2</span> }
                                else if (rank == 3) { <span class="status-tag" style="background:#cd7f32; color:#fff;">#3</span> }
                                else { <span>#@rank</span> }
                            </td>
                            <td><strong>@item.EmployeeName</strong></td>
                            <td><span class="status-tag processed">@item.DepartmentName</span></td>
                            <td><strong style="color:var(--success);">@item.Salary.ToString("N0") VNĐ</strong></td>
                        </tr>
                        rank++;
                    }
                    @if (!Model.SalaryRanking.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted">Chưa có dữ liệu bảng lương tháng này.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

<!-- Manager Lists -->
@if (Model.ShowManagerMetrics)
{
    <div class="row">
        <div class="col-md-6">
            <section class="panel mb-4">
                <h4>Danh sách phòng ban</h4>
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-modern align-middle">
                        <thead style="position: sticky; top: 0; background: #fff; z-index: 1;">
                            <tr>
                                <th>Phòng ban</th>
                                <th>Trưởng phòng</th>
                                <th>Số nhân sự</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ManagerDepartmentList)
                            {
                                <tr>
                                    <td><strong>@item.DeptName</strong></td>
                                    <td>@item.ManagerName</td>
                                    <td><span class="status-tag active">@item.EmployeeCount người</span></td>
                                </tr>
                            }
                            @if (!Model.ManagerDepartmentList.Any())
                            {
                                <tr><td colspan="3" class="text-center text-muted">Không có dữ liệu</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
        <div class="col-md-6">
            <section class="panel mb-4">
                <h4>Danh sách dự án</h4>
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-modern align-middle">
                        <thead style="position: sticky; top: 0; background: #fff; z-index: 1;">
                            <tr>
                                <th>Tên dự án</th>
                                <th>Ngân sách</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ManagerProjectList)
                            {
                                <tr>
                                    <td><strong>@item.ProjName</strong></td>
                                    <td>@item.Budget.ToString("N0") VNĐ</td>
                                    <td>
                                        @if(item.Status == "Active") { <span class="status-tag active">@item.Status</span> }
                                        else if (item.Status == "Completed") { <span class="status-tag processed">@item.Status</span> }
                                        else { <span class="status-tag pending">@item.Status</span> }
                                    </td>
                                </tr>
                            }
                            @if (!Model.ManagerProjectList.Any())
                            {
                                <tr><td colspan="3" class="text-center text-muted">Không có dữ liệu</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>
}

@if (User.IsInRole(AppRoles.Admin))
{
    <section class="content-grid two-columns mb-4">
        <article class="panel">
            <h4>Tăng trưởng nhân sự và chi phí (Admin View)</h4>
            @if(Model.MonthlyPayrollTrend.Any())
            {
                <div class="comparison-chart">
                    @foreach (var point in Model.MonthlyPayrollTrend)
                    {
                        var maxPayroll = Model.MonthlyPayrollTrend.Max(x => x.Payroll);
                        var maxBudget = Model.MonthlyPayrollTrend.Max(x => x.Budget);
                        var payrollHeight = (int)Math.Max(8m, point.Payroll / (maxPayroll == 0 ? 1 : maxPayroll) * 100m);
                        var budgetHeight = (int)Math.Max(8m, point.Budget / (maxBudget == 0 ? 1 : maxBudget) * 100m);

                        <div class="comparison-group">
                            <div class="bar bar-primary" style="height:@payrollHeight%"></div>
                            <div class="bar bar-secondary" style="height:@budgetHeight%"></div>
                            <span>@point.Label.Split(' ')[0]</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mt-3">Chưa có đủ dữ liệu lương để vẽ biểu đồ.</p>
            }
        </article>

        <article class="panel">
            <h4>Tỷ lệ giữ chân theo phòng ban (Admin View)</h4>
            <div class="retention-list">
                @foreach (var item in Model.DepartmentRetention)
                {
                    <div class="retention-item">
                        <div class="d-flex justify-content-between mb-1">
                            <span>@item.DepartmentName</span>
                            <strong>@item.RetentionPercent%</strong>
                        </div>
                        <div class="progress progress-thin">
                            <div class="progress-bar" style="width:@item.RetentionPercent%"></div>
                        </div>
                    </div>
                }
                @if(!Model.DepartmentRetention.Any())
                {
                    <p class="text-muted">Chưa có dữ liệu phòng ban.</p>
                }
            </div>
        </article>
    </section>
}
