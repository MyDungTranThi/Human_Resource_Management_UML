@model HRM.Web.Models.ViewModels.Projects.ProjectFormViewModel
@{
    ViewData["Title"] = "Thêm dự án mới";
}

<div class="page-head">
    <h1>Thêm dự án mới</h1>
    <p>Nhập thông tin chi tiết và gán phòng ban phụ trách cho dự án.</p>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <partial name="_ProjectForm" model="Model" />

    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Lưu</button>
        <a class="btn btn-secondary" asp-action="Index">Quay lại</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
